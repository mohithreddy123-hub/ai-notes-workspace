# AI Notes Workspace — Backend Environment Variables
# Copy this file to .env and fill in your values

# ── Django Core ──────────────────────────────────────────────────────────────
SECRET_KEY=your-strong-random-secret-key-here
DEBUG=False

# ── Database ─────────────────────────────────────────────────────────────────
# For local development use SQLite (leave as-is):
DATABASE_URL=sqlite:///db.sqlite3
# For production (PostgreSQL on Render/Railway), use:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── AI Provider ──────────────────────────────────────────────────────────────
# Choose one: 'gemini' (free) or 'openai' (paid)
AI_PROVIDER=gemini

# Get a free Gemini key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Get an OpenAI key at: https://platform.openai.com/api-keys (paid)
OPENAI_API_KEY=

# ── CORS / Hosts ─────────────────────────────────────────────────────────────
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Production example:
# ALLOWED_HOSTS=your-backend.onrender.com
# CORS_ALLOWED_ORIGINS=https://your-app.netlify.app

# ── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
